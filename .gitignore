# macOS / Python
.DS_Store
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
*.cache
.vscode/

# Node / build
node_modules/
dist/
build/

# ML training artifacts — exclude everything in runs/ EXCEPT the final weights.
# Must use runs/** (not runs/) so git traverses the directory and negations work.
runs/**
!runs/detect/
!runs/detect/train/
!runs/detect/train/weights/
!runs/detect/train/weights/best.pt

# Downloaded base models (not the trained weights)
yolov8n.pt
*.weights
*.onnx
*.engine

# Data (keep only the YAML)
dataset/*
!dataset/poster.yaml
posters/

# Runtime output
uploads/
static/detections/

.env
.cache
runs/detect/train/weights/best.pt
